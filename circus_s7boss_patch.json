{"team_archetypes": {"No Lands For You": {"colors": ["Black"], "archetype": "Land Destruction", "flavor": "Your opponent's lands aren't safe, their plans aren't safe, and by turn four neither is their will to live. Knights and Sengir Vampires clean up the rubble.", "key_cards": ["Sinkhole", "Strip Mine", "Icequake"], "active": true}, "Mean Machine": {"colors": ["Red"], "archetype": "Goblin Tribal", "flavor": "An army of idiots with a king, a death wish, and Goblin Grenade. Blood Moon shows up just to ruin everyone else's afternoon.", "key_cards": ["Goblin Grenade", "Blood Moon"], "active": true}, "Sliver Lining": {"colors": ["5-Color"], "archetype": "Sliver Tribal", "flavor": "Each new Sliver makes every other Sliver better, faster, and more obnoxious. Drop Coat of Arms and suddenly your opponent is doing math they didn't sign up for.", "key_cards": ["Coat of Arms"], "active": true}, "Dark N Stormy": {"colors": ["Red"], "archetype": "Burn", "flavor": "No creatures, no subtlety, no plan B. Ball Lightning, Fork, Lightning Bolt \u2014 just a stack of red cards pointed at your opponent's face until the number hits zero.", "key_cards": ["Ball Lightning", "Fork", "Lightning Bolt"], "active": true}, "Darwin's Doom": {"colors": ["Green"], "archetype": "Ramp / Big Stompy", "flavor": "Fastbond and Gaea's Touch exist so Force of Nature can ruin someone's day on turn three. Fog is there for politeness.", "key_cards": ["Fastbond", "Gaea's Touch", "Force of Nature"], "active": true}, "Trick or Treat Freaks": {"colors": ["Blue"], "archetype": "Combo Control / Mill", "flavor": "Counter your spell, pocket the mana, sneak a free 12/12 onto the table via Illusionary Mask, and let Millstone handle whoever's still standing. Mystical Tutor finds exactly what's needed, exactly when it's needed.", "key_cards": ["Illusionary Mask", "Millstone", "Mystical Tutor"], "active": true}, "Folk Music": {"colors": ["Blue"], "archetype": "Merfolk Tribal", "flavor": "Lord of Atlantis gives the whole squad Islandwalk, Phantasmal Terrain turns your opponent's lands into Islands, and suddenly your fish are unblockable. Energy Flux is just there to ruin someone's artifact-based day.", "key_cards": ["Lord of Atlantis", "Phantasmal Terrain", "Energy Flux"], "active": true}, "Holy War": {"colors": ["White"], "archetype": "White Weenie", "flavor": "Crusade, Jihad, White Knights \u2014 a self-righteous beatdown that hits harder than it has any right to. Meekstone and Kismet make sure anything bigger than your creatures stays politely tapped down forever.", "key_cards": ["Crusade", "Jihad", "Meekstone", "Kismet"], "active": true}, "Clockwork": {"colors": ["Colorless"], "archetype": "Artifact Aggro", "flavor": "Assemble the Urza's lands, produce seven colorless mana, and deploy an army of mechanical nightmares that don't care what color you're playing. Rocket Launcher handles the leftovers.", "key_cards": ["Urza's Tower", "Urza's Mine", "Urza's Power Plant", "Rocket Launcher"], "active": true}, "Bone Dry": {"colors": ["Black"], "archetype": "Discard / Control", "flavor": "Hymn to Tourach, Mind Twist, Hypnotic Specter \u2014 the hand's gone before they knew what hit them. The Rack and Megrim spend the rest of the game making them regret every card they draw.", "key_cards": ["Hymn to Tourach", "Mind Twist", "Hypnotic Specter", "The Rack", "Megrim"], "active": true}, "The Emerald Army": {"colors": ["Green"], "archetype": "Elf Tribal", "flavor": "Llanowar Elves make mana, Fyndhorn Elves make mana, Kaysa makes everyone scarier, and Overrun makes the math embarrassing. Ice Storm and Thermokarst are for opponents who had the audacity to keep lands.", "key_cards": ["Llanowar Elves", "Kaysa", "Overrun", "Ice Storm"], "active": true}, "Swamp Things": {"colors": ["Black", "Red"], "archetype": "Reanimator", "flavor": "Buried Alive finds Crimson Hellkite and Spirit of the Night; Living Death puts them all into play at once and wipes whatever was already there. A completely unreasonable amount of dragons for this early in the game.", "key_cards": ["Buried Alive", "Living Death", "Crimson Hellkite", "Spirit of the Night"], "active": true}, "Demolition Derby": {"colors": ["Black", "Green", "White"], "archetype": "Sacrifice / Reanimator", "flavor": "Survival of the Fittest fills the graveyard, Recurring Nightmare loops the best creatures back on a permanent subscription. Grave Pact plus Sengir Autocrat's token factory means your opponent is sacrificing their board whether they like it or not.", "key_cards": ["Survival of the Fittest", "Recurring Nightmare", "Grave Pact", "Sengir Autocrat"], "active": true}, "Hand Grenade": {"colors": ["Black", "Red"], "archetype": "Wheel Combo", "flavor": "Force everyone to draw constantly with Howling Mine and Teferi's Puzzle Box, let Underworld Dreams charge them for the privilege, then Winter Orb and Relic Barrier make sure they're too mana-starved to do anything about it. Chaos, but on purpose.", "key_cards": ["Howling Mine", "Teferi's Puzzle Box", "Underworld Dreams", "Winter Orb"], "active": true}, "Mist Monsters": {"colors": ["Blue"], "archetype": "Tempo Control", "flavor": "Serendib Efreet hits fast while Counterspells handle any objections. If that's not enough, there's always a free 12/12 Dreadnought hiding behind an Illusionary Mask for special occasions.", "key_cards": ["Serendib Efreet", "Illusionary Mask", "Phyrexian Dreadnought"], "active": false}, "Bad Ass Fault": {"colors": ["Black", "Red"], "archetype": "Discard / Land Destruction", "flavor": "Hypnotic Specter eats the hand while Stone Rain eats the lands. By the time your opponent stabilizes, there's nothing left to stabilize with.", "key_cards": ["Hypnotic Specter", "Stone Rain"], "active": false}, "Extinction": {"colors": ["White", "Green", "Red"], "archetype": "Midrange Control", "flavor": "Kird Ape and Lhurgoyf arrive early and hit hard; Dense Foliage makes them immune to targeted removal. If things get complicated, Wrath of God or Cataclysm reminds everyone who's actually in charge.", "key_cards": ["Kird Ape", "Lhurgoyf", "Dense Foliage", "Wrath of God"], "active": false}, "Smashed Potatoes": {"colors": ["White"], "archetype": "White Weenie / Armageddon", "flavor": "Swarm the board, build a hand with Land Tax, then Armageddon the whole table when you're ahead. Your opponent rebuilds from nothing. You don't.", "key_cards": ["Land Tax", "Armageddon", "Crusade"], "active": false}, "YCBI": {"colors": ["White", "Blue"], "archetype": "Bird Tribal", "flavor": "Soraya the Falconer leads a sky full of Falcons and Angels that nothing can block. Counterspell and Kismet handle the ground game so your air force can operate without interference.", "key_cards": ["Soraya the Falconer", "Kismet", "Counterspell"], "active": false}, "Frozen Stiffs": {"colors": ["White", "Green"], "archetype": "Tap / Prison", "flavor": "A slow, artifact-powered stranglehold that keeps creatures tapped, mana locked, and options nonexistent. Wins by making the game miserable to play into.", "key_cards": ["Winter Orb", "Static Orb"], "active": false}, "Glop Artists": {"colors": ["White", "Green"], "archetype": "Prison / Control", "flavor": "Cataclysm strips the board to almost nothing, Balance finishes the cleanup, and Argivian Archaeologist recycles the pieces that keep the prison running. A deck that wins by having slightly more than zero.", "key_cards": ["Cataclysm", "Balance", "Argivian Archaeologist"], "active": false}, "Icy Hot": {"colors": ["Blue", "Red"], "archetype": "Prison Control", "flavor": "Icy Manipulator taps anything threatening, Propaganda taxes attacks into irrelevance, and the Red splash exists mostly to keep things interesting. Control that charges admission for the privilege of playing against it.", "key_cards": ["Icy Manipulator", "Propaganda"], "active": false}, "Murphy's Law": {"colors": ["White", "Red"], "archetype": "Enchantment Aggro", "flavor": "Angelic Renewal keeps looping creatures back from the grave while enchantments stack up and make everything stickier. Harder to kill than it has any right to be.", "key_cards": ["Angelic Renewal", "Pandemonium"], "active": false}, "The Attritionists": {"colors": ["Black"], "archetype": "Swarm / Attrition", "flavor": "Bad Moon and Breeding Pit generate a constant stream of black bodies, and Grave Pact means every sacrifice takes something with it. The deck doesn't win so much as outlast everything else.", "key_cards": ["Bad Moon", "Breeding Pit", "Grave Pact"], "active": false}, "Big Gloves": {"colors": ["Red", "Black"], "archetype": "Burn / Aggro", "flavor": "Red. Black. Chain Lightning to the face. No further questions.", "key_cards": ["Chain Lightning"], "active": false}, "Fire Drilled": {"colors": ["Red"], "archetype": "Dragon Aggro", "flavor": "Dragon Whelp takes to the skies early and Earthquake clears whatever's blocking the runway. A Red deck with zero patience for subtlety.", "key_cards": ["Dragon Whelp", "Earthquake"], "active": false}, "Peak-a-Boom": {"colors": ["Green", "Blue"], "archetype": "Ramp / Tempo", "flavor": "Birds of Paradise accelerates the curve while Blue counters protect the investment. The Green/Blue deck that wants to be ahead on board and never let you catch up.", "key_cards": ["Birds of Paradise"], "active": false}, "Overdrawn": {"colors": ["Blue", "Red"], "archetype": "Chaos / Control", "flavor": "Arcane Denial handles threats while Teferi's Puzzle Box scrambles everyone's hand each turn. Wins by being slightly more comfortable with total chaos than whoever it's playing against.", "key_cards": ["Arcane Denial", "Teferi's Puzzle Box"], "active": false}, "Thrull Frottle": {"colors": ["Black"], "archetype": "Thrull Tribal", "flavor": "Basal Thrull sacrifices for mana, Armor Thrull hands out +1/+1 counters, and the whole messy engine grinds forward on vibes and recursion. Not glamorous. Effective.", "key_cards": ["Basal Thrull", "Armor Thrull"], "active": false}, "The Doldrums": {"colors": ["Blue", "White"], "archetype": "Mill / Counter Control", "flavor": "Counter first, second and third, then mill away once their initial strike has been sapped. The League's first mono-blue experiment in the making \u2014 resource denial through patience, counters, and Dreadnoughts waiting in the wings.", "key_cards": ["Millstone", "Phyrexian Dreadnought", "Counterspell", "Helm of Obedience"], "active": false}, "Team 10": {"colors": ["Black"], "archetype": "Demon / Value Control", "flavor": "Get Yawgmoth Demon into play. Everything else exists to support that singular, terrifying ambition. Black Vise punishes full hands, Winter Orb slows the world down, and when the Demon arrives, the game changes permanently.", "key_cards": ["Yawgmoth Demon", "Black Vise", "Winter Orb"], "active": false}, "Black & Blueses": {"colors": ["Black", "Blue"], "archetype": "Resource Depletion", "flavor": "Hand, library, creatures, spells \u2014 everything goes. Slow the game to a crawl, eliminate the opponent's library card by card, and punish them for discarding anything. B&B wants a drain of a game, and will counter and kill anything that seeks to stop them.", "key_cards": ["Hypnotic Specter", "Underworld Dreams", "Grindstone", "Helm of Obedience", "Stasis"], "active": false}, "Dead Heads": {"colors": ["Black", "Red"], "archetype": "Goblin / Skeleton Tribal", "flavor": "Goblins and skeletons make for an awful nice Halloween scare. A battlefield full of them guarantees a spooky cocktail of unrestrained mayhem.", "key_cards": ["Goblin Recruiter", "Goblin Bomb", "Goblins of the Flarg", "Hidden Horror", "Kjeldoran Dead"], "active": false}, "El Kamino": {"colors": ["Blue"], "archetype": "Clone Combo", "flavor": "Summon creatures, mask their identities, clone them, then hit the attack button. An army of clones is fine. An army of clones of the single largest creature in the game? Maybe bring your rabbit's foot.", "key_cards": ["Phyrexian Dreadnought", "Illusionary Mask", "Megrim", "Shocker", "Wheel of Fortune"], "active": false}, "Mystery Flavor": {"colors": ["Blue", "White"], "archetype": "Good Stuff / No Core Objective", "flavor": "One thing is for certain \u2014 there is absolutely no core objective for this group of old favorites. Similar to Team 10, the Flavors are a mish-mosh of great cards sitting idly by on the sidelines. Kind of like how a fruit cake is made, which begs the question: does anyone even like fruit cake?", "key_cards": ["Serra Angel", "Clone", "Millstone"], "active": false}, "Team 11": {"colors": ["Black", "Green"], "archetype": "Yawgmoth Demon Engine", "flavor": "Full disclosure \u2014 we'd like to get Yawgmoth Demon in play. Is he here? Yawggy? The entire roster is built around him and belle-to-be Titania's Song. A real grab bag of cards that could've been good, but were not.", "key_cards": ["Yawgmoth Demon", "Titania's Song", "Mana Vault", "Priest of Yawgmoth", "Su-Chi", "Tetravus"], "active": false}, "Green Boss": {"colors": ["Green"], "archetype": "Mana Ramp / Big Green", "flavor": "The mana engine runs so hot that Apex Altisaur and Worldspine Wurm don't feel unreasonable. Elvish Piper skips the mana cost entirely, just in case. You know what, I probably owe each of you an apology. This team is unfair.", "key_cards": ["Elvish Mystic", "Priest of Titania", "Nykthos, Shrine to Nyx", "Apex Altisaur", "Worldspine Wurm", "Elvish Piper", "Khalni Hydra"], "active": true}, "Red Boss": {"colors": ["Red"], "archetype": "Dragon / Goblin Aggro", "flavor": "Dragonspeaker Shaman and Seething Song make dragons land ahead of schedule, Lathliss spawns more dragons when they do, and Muxus dumps the entire Goblin roster onto the table in one shot. Etali and Kiki-Jiki are there to make sure things were already out of hand before you realized it.", "key_cards": ["Dragonspeaker Shaman", "Seething Song", "Lathliss, Dragon Queen", "Muxus, Goblin Grandee", "Etali, Primal Storm", "Kiki-Jiki, Mirror Breaker"], "active": true}, "Black Boss": {"colors": ["Black"], "archetype": "Tribal Swarm / Big Black", "flavor": "Death Baron and Lord of the Accursed buff the zombie horde while Vampire Nocturnus lords over the vampires and Cabal Coffers bankrolls the whole operation. Sheoldred, Phyrexian Obliterator, and Skithiryx show up when the deck wants to stop playing games.", "key_cards": ["Death Baron", "Lord of the Accursed", "Vampire Nocturnus", "Cabal Coffers", "Sheoldred, the Apocalypse", "Phyrexian Obliterator", "Skithiryx, the Blight Dragon"], "active": true}, "The Circus": {"colors": ["Red", "Green"], "archetype": "Land Destruction / Speed", "flavor": "A mixed bag of solid red and green cards built for M-Kill and speed \u2014 and an excuse to throw Kudzu out there. Ill-conceived from the start, the gameplay was excruciating. It's honestly a shock they lasted 9 games.", "key_cards": ["Kudzu", "Thermokarst", "Fallow Wurm"], "active": false}}, "season_7_boss_fight_result": {"champion": "Sliver Lining", "wins": 1, "losses": 1, "tier": "Iron Champion", "games": [{"game": 1, "boss": "Green Boss", "champion": "Sliver Lining", "winner": "Sliver Lining", "loser": "Green Boss", "winner_score": 17.0, "loser_score": -5.0, "turns": 6, "mvp": "Swords to Plowshares", "champion_won": true, "commentary": "Sliver Lining def. Green Boss in 6 turns \u2014 a dominant performance by the Season 7 champions."}, {"game": 2, "boss": "Green Boss", "champion": "Sliver Lining", "winner": "Green Boss", "loser": "Sliver Lining", "winner_score": null, "loser_score": null, "turns": null, "mvp": null, "champion_won": false, "commentary": null}]}, "all_time_teams": {"Fire Drilled": {"team": "Fire Drilled", "seasons_played": [1, 2, 3, 4, 5, 7], "total_w": 49, "total_l": 51, "total_gp": 100, "win_pct": 0.49, "championships": 1, "championship_seasons": [2], "best_power_score": 71.9, "best_power_season": 1, "season_records": [{"season": 1, "w": 8, "l": 2, "win_pct": 0.8, "power_score": 71.9, "is_champion": false, "udpi": 0.1568, "team_mvp": "Balduvian horde", "team_mvp_count"